{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simtutor.dev/schemas/v2/vision_fact_observation.json",
  "title": "Vision Fact Observation v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "observation_id",
    "timestamp",
    "source",
    "frame_ids",
    "facts"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v2" },
    "observation_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 1 },
    "session_id": { "type": ["string", "null"] },
    "trigger_wall_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frame_ids": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string", "format": "uuid" },
          { "type": "string", "pattern": "^[0-9]{1,20}_[0-9]{6}$" }
        ]
      },
      "uniqueItems": true
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fact_id",
          "state",
          "source_frame_id",
          "confidence",
          "expires_after_ms",
          "evidence_note"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "enum": [
              "left_ddi_dark",
              "right_ddi_dark",
              "ampcd_dark",
              "left_ddi_menu_root_visible",
              "left_ddi_fcs_option_visible",
              "left_ddi_fcs_page_button_visible",
              "fcs_page_visible",
              "bit_page_visible",
              "bit_root_page_visible",
              "bit_page_failure_visible",
              "right_ddi_fcsmc_page_visible",
              "right_ddi_fcs_option_visible",
              "right_ddi_in_test_visible",
              "fcs_reset_seen",
              "fcs_bit_interaction_seen",
              "fcs_bit_result_visible",
              "takeoff_trim_seen",
              "ins_alignment_page_visible",
              "ins_go"
            ]
          },
          "state": {
            "type": "string",
            "enum": ["seen", "not_seen", "uncertain"]
          },
          "source_frame_id": {
            "anyOf": [
              { "type": "string", "format": "uuid" },
              { "type": "string", "pattern": "^[0-9]{1,20}_[0-9]{6}$" }
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "expires_after_ms": {
            "type": "integer",
            "minimum": 0
          },
          "evidence_note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "observed_at_wall_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "sticky": {
            "type": ["boolean", "null"]
          }
        }
      }
    },
    "summary": {
      "type": ["string", "null"],
      "maxLength": 1000
    },
    "metadata": { "type": "object" }
  }
}
